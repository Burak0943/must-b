# ── must-b Website — Environment Variables ────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Supabase (get these from https://app.supabase.com → Project → API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# CloudAuth JWT secret (min 32 chars, used by /api/auth/connect and /api/world-verify)
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MUSTB_JWT_SECRET=change-this-to-a-secure-random-string-32-chars-min
