# ── Supabase ──────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...
# Service Role key — SADECE backend/Vercel'de kullanılır, frontend'e asla verilmez!
# Supabase Dashboard → Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ── Lemon Squeezy ─────────────────────────────────────────────────────────────
# Lemon Squeezy Dashboard → Settings → Webhooks → Signing Secret
LEMON_SQUEEZY_WEBHOOK_SECRET=your-lemon-squeezy-signing-secret

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# Must-b CloudAuth JWT imzalama sırrı (/api/auth/connect ve /api/world-verify)
MUSTB_JWT_SECRET=your-super-secret-value

# ── LLM Proxy (api/v1/chat) ───────────────────────────────────────────────────
# Virgülle ayrılmış OpenRouter API anahtarları (load balancer rastgele seçer)
OPENROUTER_API_KEYS=sk-or-v1-key1,sk-or-v1-key2,sk-or-v1-key3

# Masaüstü uygulamasının proxy'ye gönderdiği gizli header değeri
# Tanımlı değilse header'ın sadece varlığı kontrol edilir
MUSTB_NODE_SECRET=your-desktop-app-shared-secret

# OpenRouter isteğe bağlı metadata (loglama/dashboard için)
OPENROUTER_SITE_URL=https://must-b.com
OPENROUTER_SITE_NAME=must-b
